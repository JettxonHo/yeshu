# ============================================================
# 野薯(Yeshu)· 环境变量模板(.env.example)
# ------------------------------------------------------------
# 用法:cp .env.example .env,然后填入真实值。
# 铁律:本文件是模板(可 commit),真实的 .env 绝不 commit(见 .gitignore)。
#       代码只读环境变量,不硬编码任何密钥。
# ============================================================

# ---------- GitHub(任务数据真相源:Projects V2 GraphQL)----------
# Classic Token,scope 需含 project + repo。
# 注意:必须用 Classic Token —— Fine-grained PAT 不支持用户级 Projects V2。
GITHUB_TOKEN=xxx
# 你的 GitHub 用户名
GITHUB_LOGIN=xxx
# Projects V2 编号(项目 URL 里的数字)
GITHUB_PROJECT_NUMBER=xxx

# ---------- 飞书(内容真相源 + 推送目标)----------
LARK_APP_ID=xxx
LARK_APP_SECRET=xxx
# 私聊推送(V0:推给自己)
LARK_OPEN_ID=xxx
# 群推送(V1+:推到朋友群;V0 注释掉不用)
# LARK_CHAT_ID=xxx

# ---------- AI(OpenAI 兼容抽象,可切换 provider)----------
# provider 选择:deepseek / claude / openai(MVP 默认 deepseek)
AI_PROVIDER=xxx
# 例:https://api.deepseek.com/v1
AI_BASE_URL=xxx
# 例:deepseek-chat
AI_MODEL=xxx
AI_API_KEY=xxx

# ---------- Cloudflare(部署 Worker 时用)----------
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_API_TOKEN=xxx
